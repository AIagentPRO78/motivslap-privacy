  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "bun-types": "^1.1.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.1",
    "node": ">=20"
  },
  "os": ["darwin"],
  "keywords": [
    "red-team",
    "pentest",
    "offensive-security",
    "authorized-testing",
    "macbook",
    "self-hosted",
    "claude-code",
    "gstack"
