{
  "name": "redstack",
  "version": "0.1.0",
  "description": "AI-driven red-teaming product. MacBook-only operator; self-hosted Linux/macOS targets. Authorized security testing only.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun test",
    "scope:example": "cat scope.example.yaml",
    "typecheck": "tsc --noEmit",
